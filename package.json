{
  "name": "sovetydoma",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/validate-articles.mjs && node scripts/generate-build-metadata.mjs && node scripts/generate-article-index.mjs && node scripts/generate-questions-index.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs && next build",
    "start": "next start",
    "lint": "eslint src scripts workers eslint.config.mjs next.config.ts postcss.config.mjs",
    "test": "node --test scripts/__tests__/*.test.mjs src/lib/*.test.mjs && pnpm run test:photo-worker && pnpm run test:subscriptions && node scripts/audit-seo.mjs",
    "test:photo-worker": "npx tsx --test workers/photo-upload/src/*.test.ts",
    "test:subscriptions:validation": "node --test scripts/subscription-validation.test.mjs",
    "test:subscriptions:index": "node --test scripts/subscription-publication-index.test.mjs",
    "test:subscriptions:worker": "node --test workers/subscriptions/src/*.test.mjs",
    "test:subscriptions:handlers": "npx tsx --test workers/subscriptions/src/*.handler.test.ts",
    "test:subscriptions:social": "npx tsx --test workers/subscriptions/src/social/*.test.ts",
    "test:subscriptions": "pnpm run test:subscriptions:validation && pnpm run test:subscriptions:index && pnpm run test:subscriptions:worker && pnpm run test:subscriptions:handlers && pnpm run test:subscriptions:social",
    "sync:subscriptions:index": "node scripts/sync-subscription-publication-index.mjs",
    "validate:articles": "node scripts/validate-articles.mjs",
    "audit:seo": "node scripts/audit-seo.mjs",
    "audit:images": "node scripts/audit-article-images.mjs --fail-on-duplicates --fail-on-drifts --fail-on-missing-previews",
    "generate:card-images": "python scripts/generate-card-images.py",
    "generate:photo-like-images": "node scripts/generate-photo-like-images.mjs",
    "generate:procedural-photo-images": "python scripts/generate-procedural-photo-images.py",
    "fetch:openverse-images": "node scripts/fetch-openverse-images.mjs",
    "normalize:images": "python scripts/normalize-article-images.py",
    "generate:previews": "python scripts/generate-image-previews.py",
    "fix:image-frontmatter": "node scripts/fix-image-frontmatter-drifts.mjs",
    "seo:indexnow:dry": "node scripts/submit-indexnow.mjs --dry-run",
    "seo:indexnow": "node scripts/submit-indexnow.mjs",
    "matrix:seed": "node scripts/matrix/seed-from-current.mjs",
    "matrix:images": "node scripts/matrix/gen-images.mjs",
    "matrix:drafts": "node scripts/matrix/gen-drafts-grok.mjs",
    "matrix:publish": "node scripts/matrix/auto-publish.mjs",
    "matrix:publish:dry": "node scripts/matrix/auto-publish.mjs --dry-run",
    "beads:list": "node scripts/beads/list-active.mjs",
    "beads:validate": "node scripts/beads/validate-status.mjs",
    "beads:create": "node scripts/beads/create-bead.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
