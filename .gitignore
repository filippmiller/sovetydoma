# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
public/build.json

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# Stray script deps
argparse/
gray-matter/
is-extendable/
js-yaml/
kind-of/
section-matter/
strip-bom-string/

# build/test logs
*.log

.claude/scheduled_tasks.lock
/knowledge-export.json
incoming-articles/*.mdx

# deploy / infra docs that reference secret-file locations (keep out of git)
DEPLOY-TIMEWEB.md
DEPLOY-*.md
*.secrets.md
.secrets/


# transient resume note (references keys)
HANDOFF-RESUME.md

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Cloudflare Worker local dev secrets
.dev.vars
**/.dev.vars

# Codex QA screenshots / scratch artifacts
.codex-artifacts/

# content-matrix idea-gen scratch (JSON batches from Kimi)
.matrix-ideas/
matrix-exports/
public/images/_grok-test.jpg
# IndexNow key file (generated at build time from env)
public/indexnow-key.txt

# Local browser/test artifacts
.playwright-mcp/
__pycache__/
scripts/__pycache__/
.fb-test.local.json
workers/subscriptions/.fb-test.local.json
workers/subscriptions/.vk-test.local.json
workers/subscriptions/.vk-pkce.local.json
workers/subscriptions/.vk-user-token.local.json
